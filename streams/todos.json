{
    "name": "Todos",
    "handle": "todos",
    "description": "An example todos app.",
    "config": {
        "source": {
            "type": "database",
            "table": "todos"
        }
    },
    "fields": {
        "id": {
            "type": "uuid",
            "required": true,
            "unique": true,
            "config": {
                "default": true
            }
        },
        "title": {
            "type": "string",
            "required": true
        },
        "complete": "boolean"
    }
}
