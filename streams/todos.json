{
    "name": "Todos",
    "handle": "todos",
    "description": "An example todos app.",
    "config": {
        "cache": {
            "enabled": true
        }
    },
    "fields": {
        "id": {
            "type": "uuid",
            "required": true,
            "unique": true,
            "config": {
                "default": true
            }
        },
        "title": {
            "type": "string",
            "required": true
        },
        "complete": {
            "type": "boolean",
            "config": {
                "default": false
            }
        }
    }
}
